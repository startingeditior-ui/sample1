# ===========================================
# MedLinkID Patient App Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local file to version control

# ===========================================
# API Configuration
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:5002/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:5002

# ===========================================
# Firebase Configuration (Optional)
# ===========================================
# Get these from Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ===========================================
# App Configuration
# ===========================================
NEXT_PUBLIC_APP_NAME=MedLinkID
NEXT_PUBLIC_APP_VERSION=1.0.0