# ===========================================
# MedLinkID Project - Complete .gitignore
# ===========================================

# ===========================================
# Dependencies
# ===========================================
node_modules/
npm-debug.log*
yarn-error.log
yarn-debug.log
yarn.lock
package-lock.json
package.json
.pnp
.pnp.js

# ===========================================
# Testing
# ===========================================
coverage/
.nyc_output/

# ===========================================
# Next.js Frontend
# ===========================================
.next/
out/
build/
patient-app/.next/
patient-app/out/
patient-app/build/

# ===========================================
# Node.js Backend
# ===========================================
dist/
backend/dist/
backend/build/
*.tsbuildinfo

# ===========================================
# Environment Variables (CRITICAL - Never commit)
# ===========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging
*.secret
*.pem
backend/.env
patient-app/.env.local

# ===========================================
# Database Files
# ===========================================
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/*.db
prisma/*.db-journal
prisma/dev.db
prisma/dev.db-journal

# ===========================================
# IDEs and Editors
# ===========================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-*

# ===========================================
# OS Files
# ===========================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ===========================================
# Logs
# ===========================================
logs/
*.log
npm-debug.log*
yarn-error.log

# ===========================================
# Firebase / Notification Keys
# ===========================================
medlink-notification-firebase-adminsdk-*.json
firebase-adminsdk*.json
*firebase*.json
!firebase.example.json

# ===========================================
# Temporary/Debug Files
# ===========================================
nul
*.temp
*.tmp
.tmp/
temp/
debug/

# ===========================================
# Documentation (Optional - keep if needed)
# ===========================================
patient_design_pattern.md
PRD_Patient_App.md
README.md
*.md

# ===========================================
# Prisma
# ===========================================
prisma/migrations/

# ===========================================
# TypeScript Cache
# ===========================================
*.tsbuildinfo
tsconfig.tsbuildinfo

# ===========================================
# Vercel / Deployment
# ===========================================
.vercel
.output

# ===========================================
# Misc
# ===========================================
.cache/
.parcel-cache/